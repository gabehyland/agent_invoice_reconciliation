# Hyland Agent Builder — Environment Configuration
# Copy this file to .env and fill in your credentials

# IAM Authentication
HYLAND_CLIENT_ID=your-client-id-here
HYLAND_CLIENT_SECRET=your-client-secret-here
HYLAND_ENV=staging

# Agent Builder API
HYLAND_BASE_URL=https://api.agents.ai.staging.experience.hyland.com
ANALYST_AGENT_ID=your-agent-id-here
ANALYST_AGENT_VERSION=latest

# Server
PORT=3005
